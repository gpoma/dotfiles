alias cat="bat --nonprintable-notation unicode --binary as-text"
alias ls=eza
alias phpserver="PHP_CLI_SERVER_WORKERS=5 php -S localhost:8000 -t web/"
alias php74server="PHP_CLI_SERVER_WORKERS=5 php74 -S localhost:8000 -t web/"
alias telpatrick="adb connect 10.20.20.110:5555 && scrcpy"

# export BAT_THEME="Catppuccin Frappe"
export BAT_THEME="ansi"
export EDITOR=vim
export SUDO_EDITOR=vim
